<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body class="theme-<%= theme %>">
  <nav class="navbar navbar-expand-lg site-nav">
    <div class="container gap-3">
      <a class="navbar-brand brand-badge" href="/">Express застосунок</a>
      <ul class="navbar-nav me-auto mb-2 mb-lg-0 d-flex flex-row gap-2">
        <li class="nav-item"><a class="nav-link fw-bold <%= currentPath === '/' ? 'is-active' : '' %>" href="/">Головна</a></li>
        <li class="nav-item"><a class="nav-link fw-bold <%= currentPath.startsWith('/users') ? 'is-active' : '' %>" href="/users">Користувачі</a></li>
        <li class="nav-item"><a class="nav-link fw-bold <%= currentPath.startsWith('/articles') ? 'is-active' : '' %>" href="/articles">Статті</a></li>
        <li class="nav-item"><a class="nav-link fw-bold <%= currentPath.startsWith('/files') ? 'is-active' : '' %>" href="/files">Файли</a></li>
      </ul>
      <form class="theme-form d-flex gap-2 ms-auto" action="/theme" method="post">
        <input type="hidden" name="redirectTo" value="<%= currentPath || '/' %>">
        <select class="form-select form-select-sm" name="theme">
          <option value="light" <%= theme === 'light' ? 'selected' : '' %>>Світла</option>
          <option value="dark" <%= theme === 'dark' ? 'selected' : '' %>>Темна</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">Тема</button>
      </form>
    </div>
  </nav>
  <div class="container page-shell">
    <%- body %>
  </div>
</body>
</html>
